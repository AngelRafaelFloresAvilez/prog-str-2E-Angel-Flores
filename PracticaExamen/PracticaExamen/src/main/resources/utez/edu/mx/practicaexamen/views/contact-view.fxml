<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="utez.edu.mx.practicaexamen.controllers.ContactController">
   <children>
      <VBox prefHeight="302.0" prefWidth="600.0">
         <children>
            <Label text="Lista de contactos de emergencia" />
            <GridPane prefHeight="115.0" prefWidth="600.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Nombre" />
                  <Label text="Tel" GridPane.rowIndex="1" />
                  <Label text="Parentesco" GridPane.rowIndex="2" />
                  <TextField GridPane.columnIndex="1" fx:id="txtName"/>
                  <TextField GridPane.columnIndex="1" fx:id="txtTel" GridPane.rowIndex="1" />
                  <ComboBox prefWidth="150.0" fx:id="cbParentescos" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               </children>
            </GridPane>
            <ListView prefHeight="146.0" prefWidth="600.0" fx:id="listViewContacts"/>
         </children></VBox>
      <HBox prefHeight="175.0" prefWidth="600.0">
         <children>
            <Button mnemonicParsing="false" text="Agregar" onAction="#onAddContact" />
            <Button mnemonicParsing="false" text="Actualizar" onAction="#onUpdateContact"/>
            <Button mnemonicParsing="false" text="Eliminar" onAction="#onDeleteContact"/>
             <Button mnemonicParsing="false" text="Consultar" onAction="#onRequestContact"/>
             <Button mnemonicParsing="false" text="Limpiar" onAction="#onCleanContact"/>
         </children>
      </HBox>
       <Label text=" " fx:id="lblInfo" minHeight="40.0" prefHeight="40.0"/>
   </children>
</VBox>
