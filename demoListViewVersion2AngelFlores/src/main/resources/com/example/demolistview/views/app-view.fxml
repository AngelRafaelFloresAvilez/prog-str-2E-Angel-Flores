<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demolistview.controllers.AppControllers">
   <children>
      <Label alignment="CENTER" contentDisplay="CENTER" graphicTextGap="5.0" lineSpacing="1.0" text="                                                                 Registro de personas" textAlignment="RIGHT">
         <font>
            <Font name="System Bold" size="13.0" />
         </font></Label>
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <TextField fx:id="txtName" GridPane.columnIndex="1" />
            <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label alignment="CENTER_RIGHT" contentDisplay="RIGHT" text="Nombre" textAlignment="RIGHT" textFill="#8000ff" wrapText="true">
               <font>
                  <Font name="Bell MT Bold" size="12.0" />
               </font></Label>
            <Label text="Email" textFill="#7b00ff" GridPane.rowIndex="1">
               <font>
                  <Font name="Bodoni MT" size="12.0" />
               </font></Label>
            <Label text="Edad" textFill="#a600ff" GridPane.rowIndex="2" />
            <TextField fx:id="txtEdad" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <HBox prefHeight="31.0" prefWidth="600.0">
         <children>
            <Button mnemonicParsing="false" onAction="#onReload" text="Recargar" />
            <Button mnemonicParsing="false" onAction="#onAdd" text="Agregar" />
         </children>
      </HBox>
      <ListView fx:id="listView" prefHeight="235.0" prefWidth="600.0" />
      <Label fx:id="lblMsg" />
   </children>
</VBox>
